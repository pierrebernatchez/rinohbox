validargs () {
    # must be names ending in .rst
    # must exclude index.rst
    local indexedArray=()
    for myfullname in "$@" ; do
	myfullnamenoext=${myfullname%.*}
	# mybasenamenoext=${myfullnamenoext##*/}
	mybasename=${myfullname##*/}
	if [[ "${myfullname}" == "${myfullnamenoext}.rst" ]]; then
	    if [[ "${mybasename}" != "index.rst" ]]; then
		if [[ -r "${myfullname}" ]]; then
		    indexedArray+=("${myfullnamenoext}")
		fi
	    fi
	fi
    done
    local acount=${#indexedArray[@]}
    if [[ "$acount" > 0 ]] ; then
	for element in "${indexedArray[@]}"; do
	    ${ECHO} "$element"
	done
	return 0
    else
	return 1
    fi
}


if [[ $# -eq 0 ]] ; then
    # current directory *.rst 
    mapfile -t validatedargs < <(validargs ${SOURCE_RST}/*.rst)
else
    # argument line
    mapfile -t validatedargs < <(validargs "$@")
fi    

if [[ ${#validatedargs[@]} -eq 0 ]]; then
